@using CoAntiCor.Core.DTO
@inject HttpClient Http
@inject IStringLocalizer<SharedResource> Localizer
@using System.Timers
@using CoAntiCor.Resources
@using Microsoft.Extensions.Localization
@inject HttpClient Http

@* Step 1 – AI search *@
<div class="wizard-step">
    <h4>Step 1: Search existing incidents</h4>

    <p>
        Describe your incident. We will search for similar cases in the CoAntiCor system.
    </p>

    <input id="stp1-search-id" name="stp1-search-name" class="input-text" @bind="State.SearchQuery" placeholder="@Localizer["SearchCreateCompany"]" data-rule-required="true" aria-invalid="false" />
@*      <textarea class="form-control" @bind="State.SearchQuery" rows="4"></textarea> *@

    @if (_isSearching)
    {
        <button id="stp1-search-id02" class="btn btn-primary mt-2" @onclick="SearchAsync" disabled="@_isSearching">
            Searching...
        </button>
    }
    else
    {
        <button id="stp1-search-id03" class="btn btn-primary mt-2" @onclick="SearchAsync" disabled="@_isSearching">
            Search
        </button>
    }
   @*  <button class="btn btn-primary mt-2" @onclick="SearchAsync" disabled="@_isSearching">
      "Searching..." : "Search"
    </button> *@

    @if (State.SimilarIncidents.Any())
    {
        <h5 class="mt-3">Similar incidents found</h5>
        <ul class="list-group">
            @foreach (var incident in State.SimilarIncidents)
            {
                <li class="list-group-item">
                    <strong>@incident.ComplaintNumber</strong> - @incident.Title
                    <br />
                    <small>@incident.ShortDescription</small>
                </li>
            }
        </ul>

        <div class="mt-3">
            <p>
                If your case is different or you still want to report a new incident, continue.
            </p>
        </div>
    }

    <div class="mt-4">
        <button class="btn btn-success" @onclick="OnNext">Continue to new complaint</button>
    </div>
</div>

@code {
    [Parameter] public ReportIncidentWizardState State { get; set; } = default!;
    [Parameter] public EventCallback OnNext { get; set; }

    private bool _isSearching;

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(State.SearchQuery))
            return;

        _isSearching = true;

        var response = await Http.PostAsJsonAsync("/api/v1/ServiceRequest/Search", new
        {
            Term = State.SearchQuery,
            MaxResults = 10
        });

        response.EnsureSuccessStatusCode();

        var results = await response.Content.ReadFromJsonAsync<List<SimilarIncidentDto>>();
        State.SimilarIncidents = results ?? new List<SimilarIncidentDto>();

        _isSearching = false;
    }
}