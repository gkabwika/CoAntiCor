@using CoAntiCor.Core.DTO
@inject HttpClient Http
@inject IStringLocalizer<SharedResource> Localizer
@using System.Timers
@using CoAntiCor.Resources
@using Microsoft.Extensions.Localization
@inject HttpClient Http

<div class="wizard-step">
    <h4>Step 2: Select incident type and category</h4>

    <div class="mb-3">
        <label class="form-label">Incident Type</label>
        <select class="form-select" @bind="State.IncidentTypeId">
            <option value="">-- Select type --</option>
            @foreach (var type in _incidentTypes)
            {
                <option value="@type.Id">@type.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Incident Category</label>
        <select class="form-select" @bind="State.IncidentCategoryId">
            <option value="">-- Select category --</option>
            @foreach (var cat in _incidentCategories)
            {
                <option value="@cat.Id">@cat.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Title of your complaint</label>
        <input class="form-control" @bind="State.Title" />
    </div>

    <div class="mb-3">
        <label class="form-label">Describe the incident in detail</label>
        <textarea class="form-control" rows="5" @bind="State.Description"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Province of Incident</label>
      @*   <input class="form-control" @bind="State.Province" /> *@
        <select class="form-select" @bind="State.ProvinceId">
            <option value="">-- Select Province --</option>
            @foreach (var cat in _provinces)
            {
                <option value="@cat.Id">@cat.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">City or Territory of Incident</label>
        <input class="form-control" @bind="State.City" />
    </div>

    <button class="btn btn-secondary" @onclick="@OnBackClicked">Back</button>
    <button class="btn btn-primary" @onclick="NextIfValid">Next</button>
</div>

@code {
    [Parameter] public ReportIncidentWizardState State { get; set; } = default!;
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }

    private List<IncidentTypeDto> _incidentTypes = new();
    private List<IncidentCategoryDto> _incidentCategories = new();
    private List<ProvinceDto> _provinces = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _incidentCategories = await Http.GetFromJsonAsync<List<IncidentCategoryDto>>("api/v1/lookups/incidentcategories") ?? new();
           // Simulate delay for loading
            await Task.Delay(100);
            _incidentTypes = await Http.GetFromJsonAsync<List<IncidentTypeDto>>("api/v1/lookups/incidenttypes")
                     ?? new();   
            // Simulate delay for loading
            await Task.Delay(100);
            _provinces = await Http.GetFromJsonAsync<List<ProvinceDto>>("api/v1/lookups/provinces")
                     ?? new();
            
        }catch(Exception ex)
        {
            // Handle error (e.g. log, show message)
            Console.Error.WriteLine($"Error loading types/provinces, incident categories and types: {ex.Message}");
            // For simplicity, we just continue with empty lists
        }

        StateHasChanged();
    }

    private async Task NextIfValid()
    {
        if (State.IncidentTypeId is null || State.IncidentCategoryId is null || string.IsNullOrWhiteSpace(State.Description))
        {
            // TODO: show validation messages
            return;
        }

        await OnNext.InvokeAsync();
    }

    private Task OnBackClicked() => OnBack.InvokeAsync();

}