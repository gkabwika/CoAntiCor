@using CoAntiCor.Core.DTO
@inject HttpClient Http
@inject IStringLocalizer<SharedResource> Localizer
@using System.Timers
@using CoAntiCor.Resources
@using Microsoft.Extensions.Localization
@inject HttpClient Http

<div class="wizard-step">
    <h4>Step 3: Reporter information and evidence</h4>

    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" id="anonymousCheck" @bind="State.IsAnonymous" />
        <label class="form-check-label" for="anonymousCheck">
            I want to remain anonymous
        </label>
    </div>

    @if (!State.IsAnonymous)
    {
        <div class="mb-3">
            <label class="form-label">Name</label>
            <input class="form-control" @bind="State.ReporterName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input class="form-control" @bind="State.ReporterEmail" />
        </div>

        <div class="mb-3">
            <label class="form-label">Phone</label>
            <input class="form-control" @bind="State.ReporterPhone" />
        </div>
    }

    <div class="mb-3">
        <label class="form-label">Government office to send physical evidence (optional)</label>
        <select class="form-select" @bind="State.GovernmentOfficeId">
            <option value="">-- Select office --</option>
            @foreach (var office in _offices)
            {
                <option value="@office.Id">@office.Name (@office.Province - @office.City)</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Attach up to 10 documents</label>
        <InputFile OnChange="OnFilesSelected" multiple />
        <small class="text-muted">Documents, images, videos. Max 10 files.</small>

        @if (State.EvidenceFiles.Any())
        {
            <ul class="list-group mt-2">
                @foreach (var file in State.EvidenceFiles)
                {
                    <li class="list-group-item">
                        @file.FileName (@(file.Size / 1024) KB)
                    </li>
                }
            </ul>
        }
    </div>

    <button class="btn btn-secondary me-2" @onclick="HandleBack">Back</button>
    <button class="btn btn-primary" @onclick="NextIfValid">Next</button>
</div>

@code {
    [Parameter] public ReportIncidentWizardState State { get; set; } = default!;
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }

    private List<GovernmentOfficeDto> _offices = new();
    private List<ProvinceDto> _provinces = new();


    protected override async Task OnInitializedAsync()
    {
        try
        {
            _offices = await Http.GetFromJsonAsync<List<GovernmentOfficeDto>>("api/v1/lookups/governmentOffices") ?? new();
            // Simulate delay for loading
         

        }
        catch (Exception ex)
        {
            // Handle error (e.g. log, show message)
            Console.Error.WriteLine($"Error loading types/Offices: {ex.Message}");
            // For simplicity, we just continue with empty lists
        }

        StateHasChanged();
    }

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles(10);

        State.EvidenceFiles.Clear();

        foreach (var file in files)
        {
            // Here you’d typically upload to a temp storage endpoint
            using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024); // 50 MB
            var content = new StreamContent(stream);
            content.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);

            var form = new MultipartFormDataContent
            {
                { content, "file", file.Name }
            };

            var response = await Http.PostAsync("api/uploads/temp", form);
            response.EnsureSuccessStatusCode();

            var tempPath = await response.Content.ReadAsStringAsync();

            State.EvidenceFiles.Add(new UploadedFileDto
            {
                FileName = file.Name,
                ContentType = file.ContentType,
                Size = file.Size,
                TempStoragePath = tempPath
            });
        }
    }

    private async Task NextIfValid()
    {
        if (!State.IsAnonymous && string.IsNullOrWhiteSpace(State.ReporterEmail) && string.IsNullOrWhiteSpace(State.ReporterPhone))
        {
            // require at least one contact method if not anonymous
            return;
        }

        await OnNext.InvokeAsync();
    }

    private Task HandleBack() => OnBack.InvokeAsync();

}