@if (Show)
{
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Continue your draft?</h5>
                </div>
                <div class="modal-body">
                    <p>
                        A saved draft was found on this device.
                        Would you like to continue where you left off?
                    </p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="Discard">Start new</button>
                    <button class="btn btn-primary" @onclick="Resume">Continue</button>
                </div>
            </div>
        </div>
    </div>
}
@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public EventCallback OnResume { get; set; }
    [Parameter] public EventCallback OnDiscard { get; set; }

    private Task Resume() => OnResume.InvokeAsync();
    private Task Discard() => OnDiscard.InvokeAsync();
}