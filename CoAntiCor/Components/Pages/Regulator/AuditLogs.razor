@page "/regulator/audit-logs"
@using CoAntiCor.Core.Model
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@attribute [Authorize(Roles = "Executive,Regulator")]

<h3>System Audit Logs</h3>

<div class="card p-3 mb-3">
    <div class="row g-2">
        <div class="col-md-3">
            <label class="form-label">Action type</label>
            <select class="form-select" @bind="_filter.ActionType">
                <option value="">All</option>
                @foreach (var action in _actionTypes)
                {
                    <option value="@action">@action</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Entity type</label>
            <input class="form-control" @bind="_filter.EntityType" placeholder="Complaint, User..." />
        </div>
        <div class="col-md-2">
            <label class="form-label">Entity ID</label>
            <input class="form-control" @bind="_filter.EntityId" />
        </div>
        <div class="col-md-2">
            <label class="form-label">From</label>
            <InputDate class="form-control" @bind-Value="_filter.From" />
        </div>
        <div class="col-md-2">
            <label class="form-label">To</label>
            <InputDate class="form-control" @bind-Value="_filter.To" />
        </div>
        <div class="col-md-1 d-flex align-items-end">
            <button class="btn btn-primary w-100" @onclick="LoadLogs">Filter</button>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-outline-secondary" @onclick="ExportCsv">Export CSV</button>
        <button class="btn btn-outline-secondary" @onclick="ExportPdf">Export PDF</button>
    </div>
</div>

@if (_logs is null)
{
    <p>Loading...</p>
}
else if (!_logs.Any())
{
    <p>No audit entries found for the selected filters.</p>
}
else
{
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Timestamp (UTC)</th>
                <th>User</th>
                <th>Action</th>
                <th>Entity</th>
                <th>Summary</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in _logs)
            {
                <tr>
                    <td>@log.TimestampUtc.ToString("u")</td>
                    <td>@log.UserName</td>
                    <td>@log.ActionType</td>
                    <td>@log.EntityType @log.EntityId</td>
                    <td>@log.Summary</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-between align-items-center">
        <span>Page @_filter.Page</span>
        <div class="btn-group">
            <button class="btn btn-sm btn-outline-secondary" @onclick="PrevPage" disabled="@(_filter.Page <= 1)">Prev</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="NextPage" disabled="@(!_hasMore)">Next</button>
        </div>
    </div>
}

@code {
    private AuditLogFilter _filter = new() { Page = 1, PageSize = 50 };
    private List<AuditLog>? _logs;
    private bool _hasMore;
    private readonly AuditActionType[] _actionTypes = Enum.GetValues<AuditActionType>();

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        var response = await Http.PostAsJsonAsync("api/audit-logs", _filter);
        _logs = await response.Content.ReadFromJsonAsync<List<AuditLog>>() ?? new();
        _hasMore = _logs.Count == _filter.PageSize;
    }

    private async Task PrevPage()
    {
        if (_filter.Page <= 1) return;
        _filter.Page--;
        await LoadLogs();
    }

    private async Task NextPage()
    {
        if (!_hasMore) return;
        _filter.Page++;
        await LoadLogs();
    }

    private async Task ExportCsv()
    {
        var response = await Http.PostAsJsonAsync("api/audit-logs/export/csv", _filter);
        var bytes = await response.Content.ReadAsByteArrayAsync();
        await JS.InvokeVoidAsync("downloadFile", "audit-logs.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    private async Task ExportPdf()
    {
        var response = await Http.PostAsJsonAsync("api/audit-logs/export/pdf", _filter);
        var bytes = await response.Content.ReadAsByteArrayAsync();
        await JS.InvokeVoidAsync("downloadFile", "audit-logs.pdf", "application/pdf", Convert.ToBase64String(bytes));
    }

    [Inject] IJSRuntime JS { get; set; } = default!;
}